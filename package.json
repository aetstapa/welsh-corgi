{
    "name": "welsh-corgi",
    "version": "1.2.2",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        },
        "./dist/*.css": {
            "import": "./dist/*.css",
            "require": "./dist/*.css"
        }
    },
    "typings": "./dist/index.d.ts",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "autoprefixer": "^10.5.0",
        "postcss-nesting": "^14.0.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.9",
        "vite-plugin-dts": "^4.5.4"
    },
    "files": [
        "./dist"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "browserslist": [
        "cover 99.5%"
    ],
    "dependencies": {
        "motion": "^12.38.0"
    }
}
