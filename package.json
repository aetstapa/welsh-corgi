{
    "name": "welsh-corgi",
    "version": "1.2.2",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        },
        "./dist/*.css": {
            "import": "./dist/*.css",
            "require": "./dist/*.css"
        }
    },
    "typings": "./dist/index.d.ts",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "autoprefixer": "^10.4.27",
        "postcss-nesting": "^14.0.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4"
    },
    "files": [
        "./dist"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "browserslist": [
        "cover 99.5%"
    ],
    "dependencies": {
        "motion": "^12.34.4"
    }
}
